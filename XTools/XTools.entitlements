<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- XTools is a system utility: it enumerates and signals other processes
         and reads LaunchAgent/Daemon plists. The App Sandbox forbids all of
         that, so it must stay OFF (same as AnyDrag). -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>

/* Guardian */
"launch.guardian.title" = "Guardian";
"launch.guardian.header" = "Guardian";
"launch.guardian.footer" = "A Guardian rule reaps an app's leftover helper processes whenever the app itself isn't running — instantly when you quit it, and on a short poll to catch helpers that launchd re-spawns. This treats the root cause without deleting the app's LaunchAgent (which the vendor would re-add). Continuous reaping covers user-level processes; root daemons need on-demand cleanup with your password.";
